  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u796D\u7940\u9F13\u58F0"
  description: "\u949F\u58F0\u6E05\u8106\u60A0\u957F\uFF0C\u78EC\u58F0\u6D51\u539A\u56DE\u54CD\uFF0C\u9F13\u58F0\u96C4\u6D51\u5F3A\u70C8\uFF0C\u5408\u594F\u4E4B\u58F0\u5E84\u4E25\u7F13\u6162\uFF0C\u8282\u594F\u89C4\u6574\uFF1B\u8FD9\u796D\u7940\u9F13\u4E50\u8C61\u5F81\u7740\u201C\u7687\u6743\u5929\u6388\u3001\u5E84\u91CD\u8083\u7A46\u201D\uFF0C\u4F53\u73B0\u4E86\u5112\u5BB6\u201C\u796D\u5929\u7940\u795E\u201D\u7684\u793C\u4EEA\u6587\u5316\uFF0C\u5F3A\u5316\u4E86\u7687\u5BB6\u796D\u7940\u7684\u795E\u5723\u7B49\u7EA7\u611F\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u300A\u96C5\u4E50\u300B\uFF08\u300A\u7687\u671D\u793C\u5668\u56FE\u5F0F\u300B\u9644\uFF09\r\n\u539F\u6587\uFF1A\u201C\u4E2D\u548C\u97F6\u4E50\u7528\u4E8E\u5FA1\u82B1\u56ED\u56DB\u795E\u7960\u796D\u7940\u3001\u94A6\u5B89\u6BBF\u5178\u793C\uFF0C\u4E50\u5668\u6709\u939B\u949F\u3001\u7279\u78EC\u3001\u7F16\u949F\u3001\u7F16\u78EC\u3001\u5EFA\u9F13\u3001\u7BEA\u3001\u6392\u7BAB\u7B49\uFF0C\u5408\u594F\u65F6\u2018\u949F\u58F0\u60A0\u3001\u78EC\u58F0\u539A\u3001\u9F13\u58F0\u96C4\u2019\uFF0C\u8282\u594F\u9075\u793C\u4EEA\u89C4\u5236\u3002\u201D\r\n2.\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u300A\u6E05\u5BAB\u793C\u4EEA\u6863\u6848\u300B\uFF08\u4E7E\u9686\u5341\u4E09\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u56DB\u795E\u7960\u82B1\u671D\u8282\u796D\u7940\uFF0C\u949F\u9F13\u9F50\u9E23\uFF0C\u7B19\u7BAB\u5408\u594F\uFF0C\u4E50\u58F0\u4F20\u81F3\u5FA1\u82B1\u56ED\u5168\u57DF\uFF0C\u8457\u592A\u5E38\u5BFA\u4E50\u5E08\u638C\u4E4B\u3002\u201D\r\n3.\u73B0\u4EE3\u5929\u575B\u795E\u4E50\u7F72\u300A\u4E2D\u548C\u97F6\u4E50\u590D\u539F\u4E50\u8C31\u300B\uFF082024
    \u5E74\uFF09\r\n\u8BF4\u660E\uFF1A\u201C\u5FA1\u82B1\u56ED\u796D\u7940\u9F13\u4E50\u4E0E\u5929\u575B\u89C4\u5236\u4E00\u81F4\uFF0C\u949F\u58F0\u9891\u7387\u7EA6
    500Hz\uFF0C\u9F13\u58F0\u7EA6 100Hz\uFF0C\u5951\u5408\u6E05\u4EE3\u6587\u732E\u63CF\u8FF0\u3002\u201D\r\n4.\u6E05\u30FB\u300A\u796D\u7940\u56FE\u30FB\u5FA1\u82B1\u56ED\u56DB\u795E\u7960\u796D\u5178\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u796D\u575B\u4E24\u4FA7\u8BBE\u949F\u9F13\u3001\u7B19\u7BAB\uFF0C\u4E50\u5E08\u6F14\u594F\uFF0C\u65C1\u6CE8\u2018\u4E50\u58F0\u5E84\u4E25\uFF0C\u4EE5\u7940\u795E\u7075\u2019\u3002\u201D\r\n"
