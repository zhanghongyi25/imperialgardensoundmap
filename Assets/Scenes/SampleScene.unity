  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u9E33\u9E2F\u620F\u6C34"
  description: "\u9E33\u9E2F\u5212\u6C34\u7684\u8F7B\u67D4\u58F0\u4E0E\u6C34\u82B1\u6E85\u843D\u7684\u7EC6\u788E\u58F0\u4EA4\u7EC7\uFF0C\u4F34\u968F\u7740\u96CC\u9E1F\u7684\u201C\u8F7B\u67D4\u9E23\u53EB\u201D\u4E0E\u96C4\u9E1F\u7684\u201C\u4F4E\u6C89\u5E94\u548C\u201D\uFF1B\u8FD9\u8C61\u5F81\u7740\u201C\u5FE0\u8D1E\u7231\u60C5\u201D\u7684\u58F0\u97F3\uFF0C\u662F\u7687\u5BB6\u56ED\u6797\u4E2D\u201C\u5409\u7965\u5A5A\u604B\u201D\u7684\u6838\u5FC3\u610F\u8C61\uFF0C\u5951\u5408\u4E86\u5E1D\u738B\u5BF9\u5A5A\u59FB\u7F8E\u6EE1\u7684\u671F\u8BB8\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6E05\u30FB\u5F18\u5386\u300A\u5806\u79C0\u5C71\u5373\u666F\u300B\uFF08\u300A\u6E05\u4EE3\u8BD7\u6587\u96C6\u6C47\u7F16\u300B459
    \u518C\uFF09\r\n\u539F\u6587\uFF1A\u201C\u8BD5\u6696\u6587\u79BD\u8FDC\u753B\u5802\uFF0C\u9E33\u9E2F\u6E38\u5F0B\u620F\u6C60\u5858\u3002\u201D\uFF08\u201C\u6587\u79BD\u201D
    \u542B\u9E33\u9E2F\uFF09\r\n2\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u82B1\u671D\u8282\u5806\u79C0\u5C71\u524D\u9C7C\u6C60\u5185\u5E38\u53EF\u89C1\u9526\u9CA4\u548C\u9E33\u9E2F\uFF0C\u9E33\u9E2F\u620F\u6C34\u65F6\u5212\u6C34\u58F0\u4E0E\u6E85\u6C34\u58F0\u4EA4\u7EC7\u3002\u201D\r\n3.\u300A\u6545\u5BAB\u89C2\u9E1F\u6307\u5357\u300B\uFF08\u7D2B\u7981\u5B66\u5802\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6D6E\u78A7\u4EAD\u3001\u6F84\u745E\u4EAD\u6C34\u6C60\u4E3A\u9E33\u9E2F\u4E3B\u8981\u6D3B\u52A8\u533A\uFF0C\u6625\u5B63\u620F\u6C34\u9891\u7E41\uFF0C\u58F0\u97F3\u8F7B\u67D4\u3002\u201D\r\n4.\u6E05\u4EE3\u5BAB\u5EF7\u8001\u7167\u7247\u300A\u5A49\u5BB9\u5728\u6D6E\u78A7\u4EAD\u8D4F\u9E33\u9E2F\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u6C34\u6C60\u4E2D\u9E33\u9E2F\u6210\u5BF9\u620F\u6C34\uFF0C\u65C1\u6CE8\u2018\u5212\u6C34\u6709\u58F0\uFF0C\u67D4\u82E5\u7434\u4E1D\u2019\u3002\u201D\r\n"
