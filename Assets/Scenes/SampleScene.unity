  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u559C\u9E4A\u53EB\u58F0"
  description: "\u201C\u55B3\u55B3\u201D\u7684\u53EB\u58F0\u6E05\u8106\u800C\u8FDE\u7EED\uFF0C\u8282\u594F\u660E\u5FEB\uFF0C\u5E26\u7740\u9C9C\u660E\u7684\u201C\u62A5\u559C\u201D\u7279\u5F81\uFF1B\u4F5C\u4E3A\u4F20\u7EDF\u7684\u201C\u5409\u7965\u9E1F\u201D\uFF0C\u559C\u9E4A\u7684\u9E23\u53EB\u8C61\u5F81\u7740\u201C\u559C\u62A5\u5E73\u5B89\u201D\uFF0C\u5951\u5408\u4E86\u660E\u6E05\u5E1D\u738B\u5BF9\u201C\u7965\u745E\u5F81\u5146\u201D\u7684\u6C38\u6052\u8FFD\u6C42\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u660E\u30FB\u5415\u7EAA\u300A\u9E70\u9E4A\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u559C\u9E4A\u6816\u4E8E\u53E4\u67CF\u679D\u95F4\uFF0C\u632F\u7FC5\u9E23\u53EB\uFF0C\u65C1\u9898\u2018\u9E4A\u9E23\u679D\u5934\uFF0C\u58F0\u4F20\u559C\u4FE1\u2019\u3002\u201D\r\n2.\u6E05\u30FB\u300A\u6E05\u5BAB\u8BCD\u300B\uFF08\u590F\u679D\u5DE2\uFF0C1941
    \u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6668\u98CE\u5439\u521D\u6625\uFF0C\u7ED5\u5C4B\u9E4A\u58F0\u4E7E\uFF0C\u5FA1\u82D1\u6625\u5149\u597D\uFF0C\u559C\u9E4A\u62A5\u5E73\u5B89\u3002\u201D\r\n3.\u300A\u6545\u5BAB\u89C2\u9E1F\u6307\u5357\u300B\uFF08\u7D2B\u7981\u5B66\u5802\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u53E4\u6811\u3001\u7AF9\u6797\u53CA\u5C4B\u6A90\u9644\u8FD1\u5E38\u89C1\u7070\u559C\u9E4A\uFF0C\u6625\u5B63\u9E23\u53EB\u9891\u7E41\uFF0C\u58F0\u4E3A\u2018\u55B3\u55B3
    - \u55B3\u55B3\u2019\u3002\u201D\r\n4.\u6545\u5BAB\u535A\u7269\u9662 2023 \u5E74\u58C1\u7EB8\u300A\u7199\u548C\u95E8\u5916
    - \u51AC\u5B63 - \u559C\u9E4A\u300B\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u5FA1\u82B1\u56ED\u53E4\u6811\u65C1\u559C\u9E4A\u6816\u606F\uFF0C\u6807\u6CE8\u2018\u559C\u9E4A\u4E3A\u5FA1\u82B1\u56ED\u5E38\u4F4F\u9E1F\u7C7B\uFF0C\u9E23\u58F0\u5409\u7965\u2019\u3002\u201D\r\n"
