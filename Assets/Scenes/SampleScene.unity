  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u6C60\u6C34\u6F7A\u6F7A\u4E0E\u9C7C\u8DC3\u58F0"
  description: "\u6C34\u9053\u4E2D\u8FDE\u7EED\u7684\u6D41\u6C34\u58F0\u8F7B\u67D4\u8212\u7F13\uFF0C\u5076\u6709\u9C7C\u8DC3\u65F6\u6C34\u82B1\u6E85\u843D\u7684\u77ED\u4FC3\u6E05\u8106\u4E4B\u97F3\uFF1B\u6C60\u6C34\u6F7A\u6F7A\u8C61\u5F81\u7740\u201C\u751F\u673A\u6D41\u8F6C\u201D\uFF0C\u800C\u9C7C\u8DC3\u5219\u5BD3\u610F\u201C\u5E74\u5E74\u6709\u4F59\u201D\u7684\u5409\u7965\uFF0C\u8FD9\u6B63\u662F\u7687\u5BB6\u56ED\u6797\u201C\u7406\u6C34\u9020\u751F\u673A\u201D\u7406\u5FF5\u7684\u751F\u52A8\u5199\u7167\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6545\u5BAB\u5B98\u7F51\u300A\u5FA1\u82B1\u56ED\u300B\r\n\u539F\u6587\uFF1A\u201C\u6D6E\u78A7\u4EAD\u3001\u6F84\u745E\u4EAD\u8DE8\u8D8A\u6C34\u6C60\uFF0C\u6C60\u5185\u9526\u9CA4\u6E38\u5F0B\uFF0C\u6C34\u9053\u6F7A\u6F7A\uFF0C\u5076\u6709\u9C7C\u8DC3\u6E85\u6C34\u3002\u201D\r\n2.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u6D6E\u78A7\u4EAD\u3001\u6F84\u745E\u4EAD\u4E0B\u5404\u6709\u91D1\u9C7C\u6C60\uFF0C\u660E\u6E05\u65F6\u671F\u91D1\u9C7C\u6E38\u620F\u3001\u83B2\u82B1\u6447\u66F3\uFF0C\u6C60\u6C34\u6F7A\u6F7A\u4E0D\u7EDD\uFF1B\u5806\u79C0\u5C71\u524D\u9C7C\u6C60\u4EA6\u6709\u9C7C\u8DC3\u4E4B\u666F\u3002\u201D\r\n3.\u6E05\u30FB\u5F18\u5386\u300A\u5806\u79C0\u5C71\u5373\u666F\u300B\r\n\u539F\u6587\uFF1A\u201C\u8D1F\u51B0\u9526\u9B23\u6E38\u6587\u6CBC\uFF0C\u8BD5\u6696\u6587\u79BD\u8FDC\u753B\u5802\u3002\u201D\uFF08\u201C\u9526\u9B23\u201D
    \u6307\u9526\u9CA4\uFF0C\u201C\u6587\u6CBC\u201D \u6307\u9C7C\u6C60\uFF09\r\n4.\u6E05\u4EE3\u5BAB\u5EF7\u8001\u7167\u7247\u300A\u6D6E\u78A7\u4EAD\u8D4F\u9C7C\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u6C60\u6C34\u6D41\u7ECF\u6D6E\u78A7\u4EAD\u4E0B\uFF0C\u5BAB\u4EBA\u6307\u70B9\u6C60\u4E2D\u9526\u9CA4\uFF0C\u65C1\u6CE8\u2018\u6C34\u58F0\u6F7A\u6F7A\uFF0C\u9C7C\u8DC3\u6709\u58F0\u2019\u3002\u201D\r\n"
