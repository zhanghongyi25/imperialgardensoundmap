  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u81EA\u9E23\u949F\u8868\u58F0"
  description: "\u94A6\u5B89\u6BBF\u5317\u5899\u4E1C\u4FA7\u7684\u6F0F\u58F6\u6EF4\u6C34\u58F0\u201C\u6EF4\u7B54\u201D\u5747\u5300\uFF0C\u81EA\u9E23\u949F\u7684\u673A\u68B0\u949F\u58F0\u201C\u549A\u549A\u201D\u89C4\u6574\uFF1B\u8FD9\u949F\u8868\u62A5\u65F6\u58F0\u8C61\u5F81\u7740\u4E25\u8C28\u7684\u201C\u5BAB\u5EF7\u79E9\u5E8F\u201D\uFF0C\u4F53\u73B0\u4E86\u5E1D\u738B\u5BF9\u201C\u65F6\u95F4\u638C\u63A7\u201D\u7684\u6781\u5EA6\u91CD\u89C6\uFF0C\u662F\u6E05\u4EE3\u5BAB\u5EF7\u65E5\u5E38\u4F5C\u606F\u7684\u91CD\u8981\u542C\u89C9\u6807\u5FD7\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u300A\u7687\u671D\u793C\u5668\u56FE\u5F0F\u300B\u5377\u4E09\uFF08\u5317\u4EAC\u53E4\u7C4D\u51FA\u7248\u793E
    1983 \u5E74\u7248\uFF09\r\n\u539F\u6587\uFF1A\u201C\u81EA\u9E23\u949F\u8BBE\u4E8E\u5FA1\u82B1\u56ED\u5BAB\u6BBF\u949F\u697C\uFF0C\u6574\u70B9\u9E23\u949F\uFF0C\u2018\u4E00\u70B9\u4E00\u9E23\uFF0C\u4E24\u70B9\u4E8C\u9E23\u2019\uFF0C\u949F\u58F0\u54CD\u5F7B\u5FA1\u82D1\uFF1B\u6F0F\u58F6\u7F6E\u4E8E\u94A6\u5B89\u6BBF\uFF0C\u6EF4\u6C34\u5206\u523B\uFF0C\u2018\u6EF4\u58F0\u5300\u7EC6\uFF0C\u4EE5\u8BA1\u65F6\u523B\u2019\u3002\u201D\r\n2.\u6E05\u30FB\u300A\u5706\u660E\u56ED\u56DB\u5341\u666F\u56FE\u30FB\u9E3F\u6148\u6C38\u795C\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u81EA\u9E23\u949F\u697C\u7ED3\u6784\u6807\u6CE8\u2018\u949F\u9E23\u6574\u70B9\uFF0C\u58F0\u4F20\u5FA1\u82B1\u56ED\u2019\uFF0C\u4E0E\u94A6\u5B89\u6BBF\u6F0F\u58F6\u58F0\u547C\u5E94\u3002\u201D\r\n3.\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u300A\u594F\u6848\u300B\uFF08\u4E7E\u9686\u5341\u4E09\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u4FEE\u7406\u5FA1\u82B1\u56ED\u81EA\u9E23\u949F\uFF0C\u786E\u4FDD\u2018\u6574\u70B9\u949F\u58F0\u6E05\u6670\uFF0C\u65E0\u504F\u5DEE\u2019\uFF1B\u6F0F\u58F6\u2018\u6EF4\u58F0\u5747\u5300\uFF0C\u523B\u65E0\u5DEE\u8BEF\u2019\u3002\u201D\r\n"
