  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u6C34\u6CD5\u58F0"
  description: "\u6C34\u6D41\u55B7\u5C04\u7684\u201C\u54D7\u54D7\u201D\u58F0\u54CD\u4EAE\u8FDE\u7EED\uFF0C\u6C34\u82B1\u6E85\u843D\u7684\u201C\u567C\u556A\u201D\u58F0\u5BC6\u96C6\u6E05\u8106\uFF0C\u201C\u7011\u5E03\u6CC9\u201D\u4E0E\u201C\u6302\u6C34\u201D\u58F0\u97F5\u5404\u5F02\uFF1B\u8FD9\u55B7\u6CC9\u6C34\u6CD5\u58F0\u662F\u201C\u7687\u5BB6\u5A31\u4E50\u4E4B\u58F0\u201D\uFF0C\u8C61\u5F81\u7740\u201C\u5E1D\u738B\u5962\u534E\u201D\uFF0C\u5C55\u73B0\u4E86\u4E7E\u9686\u65F6\u671F\u5BF9\u201C\u4EBA\u5DE5\u9020\u666F\u201D\u6781\u81F4\u7684\u8FFD\u6C42\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u4E7E\u9686\u516B\u5E74\u9020\u5FA1\u666F\u4EAD\u5C71\u4E0A\u6C34\u6CD5\uFF0C\u2018\u7011\u5E03\u6CC9\u2019\u58F0\u5982\u96F7\uFF0C\u2018\u6C34\u8FDE\u6302\u6C34\u2019\u58F0\u5982\u4E1D\uFF0C\u6C34\u82B1\u6E85\u843D\u58F0\u2018\u5BC6\u96C6\u6E05\u8106\u2019\u3002\u201D\r\n2.\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u300A\u6E05\u5BAB\u5185\u52A1\u5E9C\u9020\u529E\u5904\u6863\u6848\u603B\u6C47\u300B\u7B2C
    10 \u518C\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u666F\u4EAD\u6C34\u6CD5\u2018\u7011\u5E03\u6CC9\u2019\u6C34\u6D41\u91CF\u5927\uFF0C\u58F0\u2018\u54D7\u7136\u2019\uFF1B\u2018\u6302\u6C34\u2019\u6C34\u6D41\u7EC6\uFF0C\u58F0\u2018\u6F7A\u6F7A\u2019\uFF0C\u8457\u753B\u5E08\u7ED8\u6C34\u6CD5\u7EB8\u6837\u65F6\u6807\u6CE8\u58F0\u97F3\u5DEE\u5F02\u3002\u201D\r\n3.\u5317\u4EAC\u65E5\u62A5
    2025 \u5E74\u300A\u5806\u79C0\u5C71\u6C34\u6CD5\u9057\u8FF9\u300B\r\n\u539F\u6587\uFF1A\u201C\u6C34\u6CD5\u2018\u7011\u5E03\u6CC9\u2019\u9057\u8FF9\uFF08\u5806\u79C0\u5C71\u5317\u5761\uFF09\u63A8\u6D4B\u6C34\u6D41\u843D\u5DEE
