  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u98CE\u5439\u53E4\u67CF\u58F0"
  description: "\u90A3\u6301\u7EED\u4F4E\u9891\u7684\u201C\u6C99\u6C99\u201D\u58F0\uFF0C\u968F\u7740\u98CE\u901F\u7684\u53D8\u5316\u8D77\u4F0F\u7740\u8282\u594F\uFF0C\u53E4\u67CF\u679D\u53F6\u6469\u64E6\u7684\u58F0\u54CD\u6E05\u6670\u53EF\u8FA8\uFF1B\u4F5C\u4E3A\u7687\u5BB6\u56ED\u6797\u201C\u81EA\u7136\u96C5\u97F5\u201D\u7684\u6838\u5FC3\uFF0C\u8FD9\u98CE\u5439\u53E4\u67CF\u58F0\u4E0D\u4EC5\u8C61\u5F81\u7740\u201C\u6C5F\u5C71\u6C38\u56FA\u201D\uFF0C\u66F4\u5728\u6E05\u5E7D\u4E2D\u6697\u542B\u4E86\u660E\u6E05\u5E1D\u738B\u5BF9\u7EDF\u6CBB\u957F\u4E45\u7684\u6BB7\u5207\u671F\u8BB8\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6545\u5BAB\u5B98\u7F51\u300A\u5FA1\u82B1\u56ED\u300B\r\n\u539F\u6587\uFF1A\u201C\u56ED\u5185\u591A\u5904\u53E4\u6811\uFF0C\u4EE5\u53E4\u67CF\u4E3A\u6700\uFF0C\u53E4\u67CF\u679D\u53F6\u7ECF\u98CE\u62C2\u52A8\uFF0C\u6C99\u6C99\u4F5C\u54CD\uFF0C\u5C3D\u663E\u6E05\u5E7D\u3002\u201D\r\n2.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\uFF08\u8D3E\u6167\u679C\uFF0C\u300A\u6545\u5BAB\u5B66\u520A\u300B\u7B2C\u4E8C\u5341\u4E94\u8F91\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5806\u79C0\u5C71\u524D\u548C\u5EF6\u6656\u9601\u5357\u96C6\u4E2D\u6210\u7247\u72B6\u53E4\u67CF\uFF0C\u5F62\u6210\u8471\u90C1\u53E4\u67CF\u6797\u3002\u201D\r\n3.\u6E05\u30FB\u5F18\u5386\u300A\u5FA1\u82B1\u56ED\u53E4\u67CF\u884C\u300B\uFF08\u300A\u6E05\u4EE3\u8BD7\u6587\u96C6\u6C47\u7F16\u300B319
    \u518C\uFF09\r\n\u539F\u6587\uFF1A\u201C\u53E4\u67CF\u53C2\u5929\u8986\u7D2B\u57A3\uFF0C\u866C\u679D\u94C1\u5E72\u5386\u971C\u5BD2\u3002\u98CE\u6765\u7FE0\u53F6\u9E23\u6E05\u54CD\uFF0C\u7591\u662F\u677E\u6D9B\u843D\u7389\u76D8\u3002\u201D\r\n4.\u6E05\u30FB\u94B1\u7EF4\u57CE\u300A\u5FA1\u82B1\u56ED\u53E4\u67CF\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u645B\u85FB\u5802\u897F\u53E4\u67CF\u866C\u66F2\uFF0C\u679D\u53F6\u8212\u5C55\uFF0C\u65C1\u6CE8\u2018\u98CE\u8FC7\u53F6\u52A8\uFF0C\u58F0\u5982\u6F31\u7389\u2019\u3002\u201D\r"
