--- !u!114 &852956027
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 852956026}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u949F\u78EC\u62A5\u65F6"
  description: "\u6F0F\u58F6\u7684\u201C\u6EF4\u6C34\u58F0\u201D\u5747\u5300\u800C\u60A0\u957F\uFF0C\u81EA\u9E23\u949F\u7684\u201C\u673A\u68B0\u949F\u58F0\u201D\u8282\u594F\u89C4\u6574\uFF0C\u66F4\u6709\u949F\u78EC\u58F0\u6E05\u8106\u56DE\u54CD\uFF1B\u9760\u8FD1\u94A6\u5B89\u6BBF\u897F\u4FA7\u7684\u8FD9\u62A5\u65F6\u4E4B\u58F0\u8C61\u5F81\u7740\u201C\u7687\u6743\u638C\u63A7\u65F6\u95F4\u201D\uFF0C\u800C\u5E84\u91CD\u7684\u949F\u78EC\u58F0\u5219\u662F\u796D\u7940\u7684\u201C\u5E84\u91CD\u4E4B\u97F3\u201D\uFF0C\u5F70\u663E\u4E86\u5BAB\u5EF7\u4E0D\u53EF\u903E\u8D8A\u7684\u201C\u79E9\u5E8F\u4E0E\u7B49\u7EA7\u201D\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u300A\u7687\u671D\u793C\u5668\u56FE\u5F0F\u300B\uFF08\u6E05\u30FB\u4E8E\u654F\u4E2D\uFF0C\u5317\u4EAC\u53E4\u7C4D\u51FA\u7248\u793E
    1983 \u5E74\u7248\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6E05\u5BAB\u94A6\u5B89\u6BBF\u5185\u7F6E\u6F0F\u58F6\u4E00\u3001\u81EA\u9E23\u949F\u4E00\uFF0C\u6F0F\u58F6\u6EF4\u6C34\u5206\u523B\uFF0C\u81EA\u9E23\u949F\u6574\u70B9\u9E23\u949F\uFF0C\u949F\u78EC\u58F0\u7ED5\u6BBF\uFF0C\u4EE5\u6B63\u65F6\u8FB0\u3002\u201D\r\n2.\u6E05\u30FB\u80E4\u799B\u300A\u96CD\u6B63\u5FA1\u5236\u8BD7\u6587\u96C6\u300B\uFF08\u4E0A\u6D77\u53E4\u7C4D\u51FA\u7248\u793E
    2010 \u5E74\u7248\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6BCF\u601C\u5F02\u57DF\u949F\u504F\u5DE7\uFF0C\u65AD\u9001\u65F6\u5149\u53EA\u51E0\u58F0\u3002\u201D\uFF08\u9898\u753B\u8BD7\uFF0C\u611F\u53F9\u81EA\u9E23\u949F\u62A5\u65F6\u58F0\uFF09\r\n3.\u6E05\u30FB\u300A\u5706\u660E\u56ED\u56DB\u5341\u666F\u56FE\u30FB\u9E3F\u6148\u6C38\u795C\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u81EA\u9E23\u949F\u697C\u7ED3\u6784\u6E05\u6670\uFF0C\u65C1\u6CE8\u2018\u949F\u9E23\u6574\u70B9\uFF0C\u58F0\u4F20\u5FA1\u82D1\u2019\uFF0C\u5FA1\u82B1\u56ED\u94A6\u5B89\u6BBF\u949F\u78EC\u58F0\u4E0E\u4E4B\u547C\u5E94\u3002\u201D\r\n4.\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u300A\u5185\u52A1\u5E9C\u594F\u9500\u6863\u300B\uFF08\u5609\u5E86\u4E8C\u5341\u4E09\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u4FEE\u7406\u94A6\u5B89\u6BBF\u5185\u6F0F\u58F6\uFF0C\u786E\u4FDD\u6EF4\u6C34\u58F0\u5300\uFF0C\u949F\u78EC\u58F0\u4EAE\u3002\u201D\r\n"
