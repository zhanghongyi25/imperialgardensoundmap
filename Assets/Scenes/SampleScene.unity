  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u9E3D\u54E8\u58F0"
  description: "\u9E3D\u54E8\u4E4B\u58F0\u6D51\u539A\u7EF5\u957F\uFF0C\u6210\u7FA4\u98DE\u63A0\u65F6\u54CD\u5F7B\u4E91\u9704\uFF0C\u5982\u201C\u7A7A\u4E2D\u4EA4\u54CD\u4E50\u201D\u822C\u7531\u8FDC\u53CA\u8FD1\uFF1B\u8FD9\u9E3D\u54E8\u58F0\u8C61\u5F81\u7740\u201C\u4EAC\u534E\u6C14\u97F5\u201D\uFF0C\u6DF1\u523B\u4F53\u73B0\u4E86\u6E05\u4EE3\u7687\u5BA4\u53CA\u516B\u65D7\u5B50\u5F1F\u201C\u5BC4\u60C5\u4E8E\u7269\u201D\u7684\u96C5\u81F4\u95F2\u60C5\uFF0C\u662F\u9A7B\u8DB3\u5FA1\u82B1\u56ED\u4EF0\u671B\u957F\u7A7A\u65F6\u6700\u5177\u6807\u5FD7\u6027\u7684\u58F0\u666F\u3002\n\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\n1. \u6E05\u30FB\u300A\u71D5\u4EAC\u5C81\u65F6\u8BB0\u300B\uFF08\u5BCC\u5BDF\u6566\u5D07\uFF09
    \u539F\u6587\uFF1A\u201C\u51E1\u653E\u9E3D\u4E4B\u65F6\uFF0C\u5FC5\u60AC\u54E8\u4E8E\u5C3E\u4E0A\u3002\u2026\u2026\u7FA4\u9E3D\u76D8\u65CB\uFF0C\u54E8\u58F0\u5165\u4E91\uFF0C\u6B64\u4EA6\u90FD\u95E8\u4E4B\u4F1F\u89C2\u4E5F\u3002\u201D\n2.
    \u6E05\u30FB\u300A\u68A6\u5382\u6742\u8457\u300B\uFF08\u4FDE\u86DF\uFF09 \u539F\u6587\uFF1A\u201C\u90FD\u4EBA\u53C8\u6709\u4EE5\u7AF9\u7BA1\u7F00\u9E3D\u5C3E\uFF0C\u2026\u2026\u98CE\u5439\u7A8D\u4F5C\u54CD\uFF0C\u5165\u4E91\u4E4B\u58F0\uFF0C\u6B63\u5982\u7B19\u7C27\u3002\u201D\n3.
    \u6C11\u56FD\u30FB\u300A\u65E7\u4EAC\u7410\u8BB0\u300B\uFF08\u590F\u4EC1\u864E\uFF0C\u8BB0\u8FF0\u6E05\u672B\u6C11\u521D\u638C\u6545\uFF09
    \u539F\u6587\uFF1A\u201C\uFF08\u65D7\u4EBA\uFF09\u5B50\u5F1F\u65E0\u4E8B\uFF0C\u591A\u597D\u7FCE\u6BDB\uFF0C\u2026\u2026\u6240\u755C\u4E4B\u9E3D\uFF0C\u98DE\u65F6\u5FC5\u7CFB\u4EE5\u94C3\u4E0E\u54E8\uFF0C\u6570\u5341\u4E3A\u7FA4\uFF0C\u58F0\u54CD\u5982\u96F7\uFF0C\u81EA\u8FDC\u800C\u8FD1\u3002\u201D"
