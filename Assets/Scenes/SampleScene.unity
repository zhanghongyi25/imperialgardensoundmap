  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u7FFB\u4E66\u58F0"
  description: "\u8F7B\u5FAE\u7684\u7EB8\u9875\u7FFB\u52A8\u58F0\u201C\u6C99\u6C99\u201D\u65AD\u7EED\uFF0C\u8282\u594F\u968F\u7740\u9605\u8BFB\u7684\u901F\u5EA6\u800C\u53D8\u5316\uFF1B\u8FD9\u58F0\u97F3\u8C61\u5F81\u7740\u201C\u5D07\u6587\u5C1A\u5B66\u201D\uFF0C\u4F53\u73B0\u4E86\u660E\u6E05\u5E1D\u738B\u5BF9\u6587\u5316\u7684\u91CD\u89C6\uFF0C\u662F\u5FA1\u82B1\u56ED\u201C\u96C5\u8DA3\u573A\u666F\u201D\u5728\u542C\u89C9\u4E0A\u7684\u7EC6\u817B\u5EF6\u4F38\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6E05\u30FB\u300A\u5341\u4E8C\u6708\u4EE4\u56FE\u30FB\u79CB\u6708\u8BFB\u4E66\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u5FA1\u82B1\u56ED\u645B\u85FB\u5802\u5185\uFF0C\u5E1D\u540E\u5750\u6848\u524D\u7FFB\u4E66\uFF0C\u7EB8\u9875\u58F0\u2018\u6C99\u6C99\u2019\uFF0C\u65C1\u6CE8\u2018\u7FFB\u4E66\u58F0\u7EC6\uFF0C\u4F34\u79CB\u98CE\u5165\u5802\u2019\u3002\u201D\r\n2.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u645B\u85FB\u5802\u4E3A\u8BFB\u4E66\u5904\uFF0C\u5E1D\u540E\u5E38\u4E8E\u6B64\u7FFB\u4E66\u8D4F\u6587\uFF0C\u7EB8\u9875\u7FFB\u52A8\u58F0\u4E3A\u5BA4\u5185\u5E38\u6001\u58F0\u3002\u201D\r\n3.\u6E05\u30FB\u300A\u5FA1\u82B1\u56ED\u751F\u6D3B\u6863\u300B\uFF08\u5609\u5E86\u5341\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u645B\u85FB\u5802\u5185\u2018\u6BCF\u65E5\u5E1D\u540E\u8BFB\u4E66\uFF0C\u7FFB\u4E66\u58F0\u4E0E\u79CB\u98CE\u58F0\u76F8\u548C\u2019\uFF0C\u8457\u5BAB\u4EBA\u8F7B\u6B65\uFF0C\u52FF\u6270\u3002\u201D\r\n4.\u96CD\u6B63\u300A\u637B\u73E0\u89C2\u732B\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u80CC\u666F\u63CF\u8FF0\uFF1A\u201C\u6848\u4E0A\u644A\u5F00\u4E66\u5377\uFF0C\u6697\u793A\u2018\u65E5\u5E38\u7FFB\u4E66\u573A\u666F\uFF0C\u7EB8\u9875\u58F0\u9690\u542B\u2019\u3002\u201D\r\n"
