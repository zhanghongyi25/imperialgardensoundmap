  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u5375\u77F3\u8DEF\u811A\u6B65\u58F0"
  description: "\u90A3\u662F\u77ED\u4FC3\u7684\u6469\u64E6\u58F0\u4E0E\u9897\u7C92\u7684\u78B0\u649E\u58F0\uFF0C\u8282\u594F\u968F\u7740\u5BAB\u5EF7\u884C\u8D70\u7684\u6B65\u4F10\u5FEB\u6162\u800C\u53D8\u5316\uFF1B\u8FD9\u811A\u6B65\u58F0\u4F5C\u4E3A\u6E38\u56ED\u573A\u666F\u7684\u81EA\u7136\u5EF6\u4F38\uFF0C\u8C61\u5F81\u7740\u201C\u95F2\u9002\u5E73\u548C\u201D\uFF0C\u4F53\u73B0\u4E86\u7687\u5BB6\u56ED\u6797\u5C06\u201C\u5B9E\u7528\u6027\u4E0E\u666F\u89C2\u6027\u7ED3\u5408\u201D\u7684\u72EC\u7279\u7279\u70B9\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6545\u5BAB\u5B98\u7F51\u300A\u5FA1\u82B1\u56ED\u300B\r\n\u539F\u6587\uFF1A\u201C\u56ED\u4E2D\u5F69\u77F3\u8DEF\u9762\u94FA\u4EE5\u5375\u77F3\uFF0C\u884C\u8D70\u65F6\u978B\u5E95\u4E0E\u77F3\u5B50\u6469\u64E6\uFF0C\u53D1\u51FA\u6C99\u6C99\u6469\u64E6\u58F0\uFF0C\u9897\u7C92\u78B0\u649E\u6E05\u6670\u53EF\u95FB\u3002\u201D\r\n2.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u5404\u5EFA\u7B51\u95F4\u4EE5\u836F\u680F\u5206\u9694\uFF0C\u8FDE\u63A5\u9053\u8DEF\u591A\u4E3A\u5375\u77F3\u94FA\u88C5\uFF0C\u4FBF\u4E8E\u884C\u8D70\u4E14\u6709\u58F0\u666F\u6548\u679C\u3002\u201D\r\n3.\u6E05\u30FB\u300A\u5FA1\u82B1\u56ED\u95F2\u6B65\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u5BAB\u4EBA\u884C\u8D70\u4E8E\u5375\u77F3\u8DEF\u4E0A\uFF0C\u65C1\u6CE8\u2018\u77F3\u8DEF\u6709\u58F0\uFF0C\u6B65\u968F\u58F0\u52A8\u2019\u3002\u201D\r\n4.\u73B0\u4EE3\u6545\u5BAB\u5BFC\u89C8\u56FE\uFF082025
    \u5E74\u7248\uFF09\r\n\u6807\u6CE8\uFF1A\u201C\u5FA1\u82B1\u56ED\u5185\u81EA\u743C\u82D1\u4E1C\u95E8\u81F3\u6D6E\u78A7\u4EAD\u3001\u6F84\u745E\u4EAD\u81F3\u517B\u6027\u658B\u8DEF\u6BB5\u4E3A\u5375\u77F3\u8DEF\u3002\u201D\r\n"
