  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u9EBB\u96C0\u53EB\u58F0"
  description: "\u6E05\u8106\u7684\u9E23\u5531\u77ED\u4FC3\u4E14\u91CD\u590D\uFF0C\u4E0D\u540C\u9E1F\u79CD\u7684\u97F3\u8272\u5DEE\u5F02\u5206\u660E\uFF0C\u559C\u9E4A\u7684\u201C\u55B3\u55B3\u201D\u4E0E\u4E4C\u9E2B\u7684\u201C\u5A49\u8F6C\u591A\u53D8\u201D\u4EA4\u7EC7\uFF1B\u8FD9\u8C61\u5F81\u7740\u201C\u81EA\u7136\u751F\u673A\u201D\u7684\u9E1F\u9E23\uFF0C\u5728\u82B1\u671D\u8282\u4E0E\u201C\u6625\u534E\u201D\u610F\u8C61\u9065\u76F8\u547C\u5E94\uFF0C\u751F\u52A8\u4F53\u73B0\u4E86\u7687\u5BB6\u56ED\u6797\u201C\u5E08\u6CD5\u81EA\u7136\u201D\u7684\u9020\u56ED\u7406\u5FF5\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u660E\u30FB\u5218\u82E5\u611A\u300A\u914C\u4E2D\u5FD7\u300B\uFF08\u5317\u4EAC\u53E4\u7C4D\u51FA\u7248\u793E
    1994 \u5E74\u7248\uFF0C\u7B2C 147 \u9875\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5947\u82B1\u5F02\u5349\uFF0C\u79BD\u58F0\u4E0A\u4E0B\uFF0C\u6625\u82B1\u79CB\u6708\uFF0C\u666F\u8272\u53EF\u4EBA\u3002\u201D\r\n2.\u6E05\u30FB\u5F18\u5386\u300A\u5806\u79C0\u5C71\u5373\u666F\u300B\uFF08\u300A\u6E05\u4EE3\u8BD7\u6587\u96C6\u6C47\u7F16\u300B459
    \u518C\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6587\u79BD\u7ED5\u753B\u5802\uFF0C\u98DE\u9E23\u9010\u6625\u5149\u3002\u201D\r\n3.\u5149\u660E\u7F51
    2025 \u5E74\u300A99% \u7684\u4EBA\u901B\u4E86\u4E2A\u5047\u6545\u5BAB\uFF1F\u300B\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u7684\u9E1F\u53EB\u866B\u9E23\uFF0C\u662F\u542C\u89C9\u4E0A\u611F\u77E5\u6545\u5BAB\u751F\u673A\u7684\u91CD\u8981\u5143\u7D20\u3002\u201D\r\n4.\u300A\u6545\u5BAB\u89C2\u9E1F\u6307\u5357\u300B\uFF08\u7D2B\u7981\u5B66\u5802
    / \u6545\u5BAB\u9752\u5C11\u7248\u7F51\u7AD9\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u5E38\u9047\u559C\u9E4A\u3001\u4E4C\u9E26\u3001\u4E4C\u9E2B\u7B49\uFF0C\u9E1F\u9E23\u58F0\u4E3A\u56ED\u6797\u5E38\u6001\u58F0\u666F\u3002\u201D\r\n"
