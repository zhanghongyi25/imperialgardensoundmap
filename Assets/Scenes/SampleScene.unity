  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u70AD\u706B\u567C\u556A"
  description: "\u8F7B\u5FAE\u65AD\u7EED\u7684\u7FFB\u4E66\u58F0\u201C\u6C99\u6C99\u201D\u4F5C\u54CD\uFF0C\u4F34\u7740\u70AD\u706B\u201C\u567C\u556A\u201D\u7206\u88C2\u548C\u706B\u82D7\u8DF3\u52A8\u7684\u58F0\u97F3\uFF1B\u7FFB\u4E66\u58F0\u8C61\u5F81\u7740\u201C\u5D07\u6587\u5C1A\u5B66\u201D\uFF0C\u70AD\u706B\u58F0\u5219\u5E26\u6765\u4E86\u201C\u51AC\u65E5\u6E29\u6696\u201D\uFF0C\u4E8C\u8005\u4EA4\u7EC7\uFF0C\u751F\u52A8\u4F53\u73B0\u4E86\u7687\u5BB6\u201C\u6587\u6CBB\u4E0E\u751F\u6D3B\u7ED3\u5408\u201D\u7684\u751F\u52A8\u573A\u666F\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6E05\u30FB\u300A\u5341\u4E8C\u6708\u4EE4\u56FE\u30FB\u51AC\u6708\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u5FA1\u82B1\u56ED\u6696\u9601\u5185\uFF0C\u5E1D\u540E\u56F4\u7089\u8BFB\u4E66\uFF0C\u6848\u4E0A\u4E66\u5377\u7FFB\u5F00\uFF0C\u7089\u4E2D\u70AD\u706B\u567C\u556A\uFF0C\u65C1\u6CE8\u2018\u7FFB\u4E66\u58F0\u7EC6\uFF0C\u70AD\u706B\u58F0\u660E\u2019\u3002\u201D\r\n2.\u6E05\u30FB\u80E4\u799B\u300A\u6301\u8868\u5BF9\u83CA\u56FE\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u80CC\u666F\u63CF\u8FF0\uFF1A\u201C\u6696\u9601\u8BBE\u70AD\u7089\uFF0C\u65C1\u6709\u4E66\u67B6\uFF0C\u6697\u793A\u2018\u51AC\u65E5\u5E38\u4E8E\u6B64\u8BFB\u4E66\uFF0C\u70AD\u706B\u4E0E\u7FFB\u4E66\u58F0\u76F8\u4F34\u2019\u3002\u201D\r\n3.\u300A\u6E05\u5BAB\u8FF0\u95FB\u300B\uFF08\u7AE0\u4E43\u709C\u7B49\uFF0C\u6545\u5BAB\u51FA\u7248\u793E
    2009 \u5E74\u7248\uFF0C\u7B2C 542 \u9875\uFF09\r\n\u539F\u6587\uFF1A\u201C\u645B\u85FB\u5802\u4E3A\u5FA1\u82B1\u56ED\u8BFB\u4E66\u5904\uFF0C\u51AC\u8BBE\u70AD\u7089\u53D6\u6696\uFF0C\u5E1D\u540E\u5E38\u4E8E\u6B64\u7FFB\u4E66\u8D4F\u6587\uFF0C\u70AD\u706B\u567C\u556A\u58F0\u4E0E\u4E66\u9875\u58F0\u4EA4\u7EC7\u3002\u201D\r\n4.\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u300A\u5185\u52A1\u5E9C\u6D3B\u8BA1\u6863\u300B\uFF08\u4E7E\u9686\u516D\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u4E3A\u645B\u85FB\u5802\u6DFB\u5236\u70AD\u7089\u4E8C\u3001\u4E66\u67B6\u56DB\uFF0C\u8457\u4EBA\u6BCF\u65E5\u6DFB\u70AD\uFF0C\u786E\u4FDD\u2018\u7089\u706B\u6709\u58F0\uFF0C\u8BFB\u4E66\u4E0D\u5BD2\u2019\u3002\u201D\r\n"
