  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u7434\u745F\u4E50\u58F0"
  description: "\u5F26\u97F3\u6E05\u96C5\u60A0\u957F\uFF0C\u97F3\u8272\u6E29\u6DA6\uFF0C\u8282\u594F\u8212\u7F13\uFF0C\u5355\u97F3\u6301\u7EED\u56DE\u8361\uFF1B\u7434\u745F\u4E4B\u58F0\u8C61\u5F81\u7740\u201C\u6587\u4EBA\u9AD8\u6D01\u201D\uFF0C\u5951\u5408\u4E86\u660E\u6E05\u5E1D\u738B\u5BF9\u201C\u6587\u4EBA\u96C5\u8DA3\u201D\u7684\u5D07\u5C1A\uFF0C\u6784\u6210\u4E86\u5FA1\u82B1\u56ED\u201C\u7CBE\u795E\u666F\u89C2\u201D\u4E2D\u4E0D\u53EF\u6216\u7F3A\u7684\u4E00\u90E8\u5206\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6E05\u30FB\u300A\u7434\u68CB\u4E66\u753B\u56FE\u30FB\u5FA1\u82B1\u56ED\u629A\u7434\u300B\uFF08\u6545\u5BAB\u535A\u7269\u9662\u85CF\uFF09\r\n\u753B\u9762\u63CF\u8FF0\uFF1A\u201C\u5983\u5AD4\u4E8E\u5806\u79C0\u5C71\u4EAD\u53F0\u629A\u7434\uFF0C\u7434\u97F3\u7ED5\u4EAD\uFF0C\u65C1\u9898\u2018\u5BAB\u5973\u629A\u7434\u58F0\u60A0\u60A0\uFF0C\u7A7F\u7AF9\u5165\u4E91\u4E0D\u7A0D\u6B47\u2019\u3002\u201D\r\n2.\u6E05\u30FB\u300A\u94A6\u5B89\u6BBF\u9898\u7434\u300B\uFF08\u300A\u6E05\u4EE3\u8BD7\u6587\u96C6\u6C47\u7F16\u300B323
    \u518C\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82D1\u4EAD\u53F0\u8BBE\u7434\u745F\uFF0C\u5BAB\u5973\u629A\u7434\u58F0\u60A0\u60A0\uFF0C\u7ED5\u6881\u4E09\u65E5\u6709\u4F59\u97F5\u3002\u201D\r\n3.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u4EAD\u53F0\uFF08\u5982\u4E07\u6625\u4EAD\u3001\u5806\u79C0\u5C71\u5FA1\u666F\u4EAD\uFF09\u4E3A\u6587\u4EBA\u96C5\u96C6\u5904\uFF0C\u5E38\u8BBE\u7434\u745F\uFF0C\u4F9B\u5E1D\u540E\u8D4F\u73A9\u3002\u201D\r\n4.\u6E05\u30FB\u300A\u5FA1\u82B1\u56ED\u9648\u8BBE\u6863\u300B\uFF08\u4E7E\u9686\u5341\u4E5D\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u4E07\u6625\u4EAD\u897F\u4FA7\u8BBE\u7434\u6848\u4E00\u5F20\uFF0C\u7434\u745F\u4E00\u5177\uFF0C\u8457\u4E13\u4EBA\u770B\u7BA1\uFF0C\u5E1D\u540E\u6E38\u56ED\u65F6\u53EF\u594F\u3002\u201D\r\n"
