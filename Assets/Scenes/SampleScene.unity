  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u5F69\u77F3\u8DEF\u811A\u6B65\u58F0"
  description: "\u6469\u64E6\u58F0\u4E2D\u4F34\u968F\u7740\u9897\u7C92\u78B0\u649E\u7684\u58F0\u54CD\uFF0C\u56E0\u5F69\u77F3\u9897\u7C92\u66F4\u5927\uFF0C\u58F0\u97F3\u6BD4\u5375\u77F3\u8DEF\u663E\u5F97\u66F4\u4E3A\u539A\u91CD\uFF1B\u8FD9\u5F69\u77F3\u8DEF\u4E0A\u7684\u811A\u6B65\u58F0\u8C61\u5F81\u7740\u201C\u6C89\u7A33\u5E84\u91CD\u201D\uFF0C\u4E0E\u4E1C\u90E8\u6587\u4EBA\u666F\u89C2\u7684\u96C5\u8DA3\u5B8C\u7F8E\u5951\u5408\uFF0C\u662F\u5FA1\u82B1\u56ED\u7279\u8272\u9053\u8DEF\u72EC\u6709\u7684\u542C\u89C9\u5370\u8BB0\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u6545\u5BAB\u5B98\u7F51\u300A\u5FA1\u82B1\u56ED\u300B\r\n\u539F\u6587\uFF1A\u201C\u5FA1\u82B1\u56ED\u5185\u4E07\u6625\u4EAD\u81F3\u7EDB\u96EA\u8F69\u3001\u645B\u85FB\u5802\u81F3\u4F4D\u80B2\u658B\u8DEF\u6BB5\u4E3A\u5F69\u77F3\u94FA\u9053\uFF0C\u884C\u8D70\u65F6\u58F0\u97F3\u539A\u91CD\uFF0C\u9897\u7C92\u78B0\u649E\u58F0\u6E05\u6670\u3002\u201D\r\n2.\u300A\u78A7\u74E6\u6731\u7FDA\u8D3B\u80DC\u56FD\u300B\r\n\u539F\u6587\uFF1A\u201C\u4E7E\u9686\u5341\u4E09\u5E74\u4FEE\u7F2E\u7EDB\u96EA\u8F69\u65F6\uFF0C\u540C\u6B65\u94FA\u8BBE\u4E07\u6625\u4EAD\u81F3\u7EDB\u96EA\u8F69\u5F69\u77F3\u8DEF\uFF0C\u2018\u77F3\u5927\u800C\u5300\uFF0C\u884C\u5219\u6709\u58F0\u2019\u3002\u201D\r\n3.\u6E05\u30FB\u300A\u5FA1\u82B1\u56ED\u9053\u8DEF\u4FEE\u7F2E\u6863\u300B\uFF08\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u85CF\uFF0C\u4E7E\u9686\u5341\u4E09\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u5F69\u77F3\u8DEF\u94FA\u4E8E\u4E07\u6625\u4EAD\u81F3\u7EDB\u96EA\u8F69\uFF0C\u957F\u4E09\u5341\u4E08\uFF0C\u5BBD\u516B\u5C3A\uFF0C\u77F3\u8272\u6591\u6593\uFF0C\u884C\u6709\u58F0\u3002\u201D\r\n4.\u73B0\u4EE3\u6545\u5BAB\u5BFC\u89C8\u56FE\uFF082025
    \u5E74\u7248\uFF09\r\n\u6807\u6CE8\uFF1A\u201C\u5F69\u77F3\u8DEF\u96C6\u4E2D\u4E8E\u5FA1\u82B1\u56ED\u4E1C\u90E8\uFF0C\u8FDE\u63A5\u4E07\u6625\u4EAD\u3001\u7EDB\u96EA\u8F69\u3001\u645B\u85FB\u5802\u3002\u201D\r\n"
