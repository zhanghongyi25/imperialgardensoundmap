  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 80c48760c36484e76af2d8c5198bde5b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  pointName: "\u9E33\u9E2F\u53EB\u58F0"
  description: "\u53D7\u60CA\u65F6\u7684\u201C\u55C4\u513F\u201D\u58F0\u5C16\u9510\u77ED\u4FC3\uFF0C\u800C\u4F34\u4FA3\u4E92\u52A8\u65F6\u5219\u53D1\u51FA\u7EA4\u7EC6\u7684\u201C\u8F7B\u67D4\u9E23\u53EB\u201D\uFF1B\u8FD9\u9E33\u9E2F\u7684\u53EB\u58F0\u662F\u201C\u81EA\u7136\u4E92\u52A8\u4E4B\u58F0\u201D\uFF0C\u53D7\u60CA\u4E4B\u97F3\u4F53\u73B0\u4E86\u751F\u6001\u7684\u9C9C\u6D3B\uFF0C\u4E92\u52A8\u4E4B\u97F3\u5219\u547C\u5E94\u4E86\u201C\u5FE0\u8D1E\u201D\u7684\u5BD3\u610F\uFF0C\u6781\u5927\u5730\u4E30\u5BCC\u4E86\u56ED\u6797\u7684\u751F\u673A\u3002\r\n\r\n\u5177\u4F53\u6587\u732E
    / \u4F5C\u54C1\uFF1A\r\n1.\u300A\u6545\u5BAB\u89C2\u9E1F\u6307\u5357\u300B\uFF08\u7D2B\u7981\u5B66\u5802
    / \u6545\u5BAB\u9752\u5C11\u7248\u7F51\u7AD9\uFF09\r\n\u539F\u6587\uFF1A\u201C\u9E33\u9E2F\u53D7\u60CA\u65F6\u53D1\u51FA\u5C16\u9510\u2018\u55C4\u513F\u2019\u58F0\uFF0C\u591A\u89C1\u4E8E\u5FA1\u82B1\u56ED\u6C34\u9053\u53CA\u9C7C\u6C60\uFF1B\u4F34\u4FA3\u4E92\u52A8\u65F6\u5219\u6709\u8F7B\u67D4\u9E23\u53EB\uFF0C\u58F0\u7EC6\u5982\u4E1D\u3002\u201D\r\n2.\u4E07\u79D1\u516C\u76CA\u57FA\u91D1\u4F1A\u300A2024
    \u5E74\u6587\u534E\u98DE\u7FBD\u96C6\u300B\r\n\u539F\u6587\uFF1A\u201C2024 \u5E74
    4 \u6708\uFF0C\u6D6E\u78A7\u4EAD\u6C34\u6C60\u89C2\u6D4B\u5230\u9E33\u9E2F\u4F34\u4FA3\u4E92\u52A8\uFF0C\u53D1\u51FA\u2018\u8F7B\u67D4\u77ED\u9E23\u2019\uFF1B5
    \u6708\u89C2\u6D4B\u5230\u53D7\u60CA\u65F6\u2018\u55C4\u513F\u2019\u58F0\uFF0C\u6301\u7EED\u7EA6
    1-2 \u79D2\u3002\u201D\r\n3.\u6E05\u30FB\u300A\u5FA1\u82B1\u56ED\u6C34\u79BD\u9972\u517B\u6863\u300B\uFF08\u4E2D\u56FD\u7B2C\u4E00\u5386\u53F2\u6863\u6848\u9986\u85CF\uFF0C\u540C\u6CBB\u5341\u5E74\uFF09\r\n\u539F\u6587\uFF1A\u201C\u6D6E\u78A7\u4EAD\u9C7C\u6C60\u9E33\u9E2F\uFF0C\u53D7\u60CA\u5219\u5C16\u9E23\uFF0C\u4F34\u5219\u67D4\u9E23\uFF0C\u8457\u4EBA\u8BB0\u5F55\u5176\u58F0\u3002\u201D\r\n"
